# A Replit-only dev plugin (@builder.io/vite-plugin-jsx-loc) declares an old
# peer range for vite, which conflicts with vite 7 and makes a clean
# `npm install` fail with ERESOLVE. legacy-peer-deps lets the install proceed
# (the plugin still works; the peer range is just stale metadata). Needed for
# the Render build to succeed.
legacy-peer-deps=true
